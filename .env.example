# ExLlamaV2 Backend Configuration
# ================================

# Set to 'true' to use mock engine for local development (CPU-only, no CUDA/GPU required)
# Set to 'false' or leave empty to use real ExLlamaV2 engine (requires GPU)
USE_MOCK_ENGINE=true

# Phase 6 model paths (required if USE_MOCK_ENGINE=false)
# Qwen is the fast FIM autocomplete model.
QWEN_AUTOCOMPLETE_MODEL_DIR=

# Llama target/draft are the heavy speculative rewrite models.
LLAMA_REWRITE_TARGET_MODEL_DIR=
LLAMA_REWRITE_DRAFT_MODEL_DIR=

# Backward-compatible fallback for QWEN_AUTOCOMPLETE_MODEL_DIR.
# Prefer QWEN_AUTOCOMPLETE_MODEL_DIR for new setups.
EXLLAMA_MODEL_DIR=

# Optional Qwen tokenizer override. Defaults to QWEN_AUTOCOMPLETE_MODEL_DIR when set.
EDITOR_TOKENIZER_MODEL=

# Static KV cache length for all real ExLlamaV2 models.
# Qwen autocomplete uses 8-bit cache. Llama speculative rewrite uses Q4 cache
# because ExLlamaV2 dynamic generation does not support 8-bit cache.
MAX_SEQ_LEN=8192

# Autocomplete decoding controls
# Use a base Qwen2.5-Coder EXL2 model for Phase 5 fast-path autocomplete.
GENERATION_TEMPERATURE=0.2
GENERATION_TOP_P=0.9
GENERATION_TOP_K=40
GENERATION_REPETITION_PENALTY=1.05
GENERATION_DRY_MULTIPLIER=0.35
GENERATION_DRY_ALLOWED_LENGTH=2
GENERATION_DRY_BASE=1.75
GENERATION_DRY_RANGE=512

# Rewrite controls
# Set ENABLE_SPECULATIVE_REWRITE=false to run an 8B target-only A/B test.
ENABLE_SPECULATIVE_REWRITE=true
SPECULATIVE_DRAFT_TOKENS=1
REWRITE_MAX_NEW_TOKENS=128
REWRITE_TEMPERATURE=0.2
REWRITE_TOP_P=0.8
REWRITE_TOP_K=40
REWRITE_REPETITION_PENALTY=1.05

# Frontend Configuration
# =====================

# WebSocket server URL for the editor backend
# Default: ws://127.0.0.1:8000/ws/editor
EDITOR_WS_URL=ws://127.0.0.1:8000/ws/editor

# Server Configuration
# ====================

# Host to bind the FastAPI server to
# Use 0.0.0.0 to allow connections from other machines
SERVER_HOST=127.0.0.1

# Port to run the FastAPI server on
SERVER_PORT=8000

# Enable debug mode (verbose logging)
DEBUG=false
